# FerreRAP — Variables de entorno
# Copiá este archivo como .env y completá los valores

# URL de tu proyecto Supabase (ej: https://xxxxxxxxxxxx.supabase.co)
SUPABASE_URL=https://TU-PROYECTO.supabase.co

# anon/public key de Supabase (Settings → API → Project API keys → anon public)
SUPABASE_KEY=TU_ANON_KEY_AQUI

# Margen de ganancia por defecto en porcentaje (50 = 50%)
MARGEN_GANANCIA=50
